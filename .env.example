# Database (PostgreSQL 16 + PostGIS)
DB_URL=jdbc:postgresql://localhost:5432/farragh
DB_USERNAME=farragh
DB_PASSWORD=changeme

# Auth
JWT_SECRET=changeme-use-a-long-random-string-in-real-envs
JWT_EXPIRATION_MS=86400000

# CORS
APP_CORS_ALLOWED_ORIGINS=http://localhost:4200

# Payments — CMI (Morocco). MOCK mode: no real gateway calls, payment status is simulated.
CMI_MODE=mock
CMI_MERCHANT_ID=changeme
CMI_STORE_KEY=changeme
CMI_API_URL=https://payment.cmi.co.ma/fim/est3Dgate

# Email (pickup confirmations, recycler notifications)
SMTP_HOST=changeme
SMTP_PORT=587
SMTP_USER=changeme
SMTP_PASSWORD=changeme

# App
APP_BASE_URL=http://localhost:8080
